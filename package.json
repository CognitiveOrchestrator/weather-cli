{
  "name": "weather-cli",
  "version": "2.0.0",
  "description": "🌤️ 美化版天气查询CLI工具 - 支持高德天气API，多日预报，空气质量，24小时预报",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "weather": "dist/index.js",
    "weather-cli": "dist/index.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"No lint configured\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "weather",
    "cli",
    "typescript",
    "gaode",
    "amap",
    "open-meteo",
    "forecast",
    "air-quality"
  ],
  "author": "CrazyMinions",
  "license": "MIT",
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "gradient-string": "^3.0.0",
    "node-cache": "^5.1.2",
    "node-geocoder": "^4.4.1",
    "ora": "^9.3.0",
    "string-width": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/node-geocoder": "^4.2.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
